            { "target": "npc", "stat": "friendliness", "delta": 5 },
            { "target": "npc", "stat": "respect", "delta": 5 }
          ]
        },
        {
          "text": "Hyvä prosessi voittaa paniikin.",
          "effects": [{ "target": "npc", "stat": "respect", "delta": 10 }]
        },
        {
          "text": "En minä ehdi miettiä muiden ongelmia.",
          "effects": [
            { "target": "npc", "stat": "anger", "delta": 10 },
            { "target": "npc", "stat": "friendliness", "delta": -10 }
          ]
        }
