        {
          "text": "Onhan tässä opittavaa, mutta pärjään.",
          "effects": [{ "target": "npc", "stat": "respect", "delta": 10 }]
        },
        {
          "text": "Ei kuulu sinulle.",
          "effects": [
            { "target": "npc", "stat": "anger", "delta": 15 },
